{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/TengraStudio/tengra-market/main/mcp/mcp-manifest.schema.json",
  "title": "Tengra MCP Plugin Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "author",
    "version",
    "downloadUrl",
    "itemType",
    "category",
    "command",
    "args"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "downloadUrl": {
      "type": "string",
      "format": "uri"
    },
    "itemType": {
      "const": "mcp"
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "command": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "args": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "maxLength": 1024
      }
    },
    "entrypointUrl": {
      "type": "string",
      "format": "uri"
    },
    "entrypointFile": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9._-]+\\.(mjs|js|cjs)$"
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "permissionProfile": {
      "enum": [
        "read-only",
        "workspace-only",
        "network-enabled",
        "destructive",
        "full-access"
      ]
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        },
        "additionalProperties": false
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "dataPath": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "quotaMb": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2048
        },
        "migrationVersion": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    }
  },
  "additionalProperties": false
}
