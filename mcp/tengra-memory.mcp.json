{
  "id": "tengra-memory",
  "name": "Tengra Memory",
  "description": "Small local JSON-backed remember, recall, and forget tools packaged as an external MCP plugin.",
  "author": "Tengra Studio",
  "version": "1.0.0",
  "downloadUrl": "https://raw.githubusercontent.com/TengraStudio/tengra-market/main/mcp/tengra-memory.mcp.json",
  "itemType": "mcp",
  "category": "memory",
  "command": "node",
  "args": [],
  "entrypointUrl": "https://raw.githubusercontent.com/TengraStudio/tengra-market/main/mcp/tengra-mcp-runner.mjs",
  "entrypointFile": "server.mjs",
  "env": {
    "TENGRA_MCP_PLUGIN_ID": "tengra-memory"
  },
  "permissionProfile": "full-access",
  "tools": [
    {
      "name": "remember",
      "description": "Save a short memory record in plugin-local storage."
    },
    {
      "name": "recall",
      "description": "Search plugin-local memory records."
    },
    {
      "name": "forget",
      "description": "Delete a plugin-local memory record by id."
    }
  ],
  "storage": {
    "dataPath": "tengra-memory",
    "quotaMb": 128,
    "migrationVersion": 1
  },
  "capabilities": [
    "memory",
    "storage"
  ]
}
