{
  "id": "tengra-docker",
  "name": "Tengra Docker",
  "description": "Docker container, image, and stats inspection tools packaged as an external MCP plugin.",
  "author": "Tengra Studio",
  "version": "1.0.0",
  "downloadUrl": "https://raw.githubusercontent.com/TengraStudio/tengra-market/main/mcp/tengra-docker.mcp.json",
  "itemType": "mcp",
  "category": "workspace",
  "command": "node",
  "args": [],
  "entrypointUrl": "https://raw.githubusercontent.com/TengraStudio/tengra-market/main/mcp/tengra-mcp-runner.mjs",
  "entrypointFile": "server.mjs",
  "env": {
    "TENGRA_MCP_PLUGIN_ID": "tengra-docker"
  },
  "permissionProfile": "read-only",
  "tools": [
    {
      "name": "listContainers",
      "description": "List Docker containers with structured output."
    },
    {
      "name": "stats",
      "description": "Read one-shot Docker container stats."
    },
    {
      "name": "listImages",
      "description": "List local Docker images with structured output."
    }
  ],
  "storage": {
    "dataPath": "tengra-docker",
    "quotaMb": 32,
    "migrationVersion": 1
  },
  "capabilities": [
    "docker"
  ]
}
