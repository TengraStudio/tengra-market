{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/TengraStudio/tengra-market/main/languages/locale-pack.schema.json",
  "title": "Tengra Locale Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "locale",
    "displayName",
    "nativeName",
    "version",
    "translations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "locale": {
      "type": "string",
      "minLength": 2,
      "maxLength": 32,
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "nativeName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32,
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "baseLocale": {
      "type": "string",
      "minLength": 2,
      "maxLength": 32,
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "rtl": {
      "type": "boolean"
    },
    "coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "schemaVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32,
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "translations": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    }
  },
  "$defs": {
    "jsonValue": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
